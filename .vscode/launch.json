{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "Debug train_grpo condition D",
        "type": "debugpy",
        "request": "launch",
        "program": "${workspaceFolder}/scripts/train_grpo.py",
        "cwd": "${workspaceFolder}",
        "console": "integratedTerminal",
        "justMyCode": false,
        "env": {
          "CUDA_VISIBLE_DEVICES": "0"
        },
        "args": [
          "--no-few-shot-examples",
          "--condition", "D",
          "--max-steps", "1000",
          "--resume", "outputs/grpo_condition_D/checkpoint-800"
        ]
      },
      {
        "name": "Debug ifbench evaluation",
        "type": "debugpy",
        "request": "launch",
        "module": "run_eval",
        "cwd": "${workspaceFolder}",
        "console": "integratedTerminal",
        "justMyCode": false,
        "python": "${workspaceFolder}/external_repos/IFBench/.venv/bin/python",
        "args": [
          "--input_data=data/ifbench/input_test_data.jsonl",
          "--input_response_data=data/ifbench/qwen3-8b.jsonl",
          "--output_dir=data/ifbench/qwen3-8b_evaluation/"
        ]
      }
    ]
  }